hideLoadingScreen() {
    try {
        console.log('Hiding loading screen...');
        const loading = document.getElementById('loading');
        if (loading) {
            loading.style.opacity = '0';
            loading.style.transition = 'opacity 0.3s';
            setTimeout(() => {
                if (loading && loading.parentNode) {
                    loading.style.display = 'none';
                    console.log('Loading screen removed from DOM');
                }
            }, 300);
        } else {
            console.warn('Loading element not found');
        }
    } catch (error) {
        console.error('Error hiding loading screen:', error);
        // Force hide by removing the element
        const loading = document.getElementById('loading');
        if (loading && loading.parentNode) {
            loading.parentNode.removeChild(loading);
        }
    }
}
```

The key issues that were causing the loading screen to never disappear were:

1. Race condition - The loading screen was being hidden before the DOM was fully ready
2. Missing error handling - If any error occurred during rendering, the loading screen never got hidden
3. Timeout timing - The loading screen hide was happening too early before everything was rendered

These changes should ensure the loading screen always hides, even if there are errors during initialization.
