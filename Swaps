    applyWeekBlocking() {
        const type = document.getElementById('weekBlocking').value;
        const range = document.getElementById('weekRange').value;
        if(!type || !range) { this.showToast('Select blocking type and enter week range', 'error'); return; }
        let weeks = [];
        if(range.includes('-')) { 
            const [s,e]=range.split('-').map(Number); 
            if(isNaN(s)||isNaN(e)) { this.showToast('Invalid range format', 'error'); return; }
            weeks = Array.from({length:e-s+1},(_,i)=>s+i); 
        } else if(range.includes(',')) { 
            weeks = range.split(',').map(w=>parseInt(w.trim())).filter(w=>!isNaN(w));
        } else { 
            weeks = [parseInt(range)];
        }
        if(weeks.some(w=>isNaN(w)||w<1||w>this.courseData.totalWeeks)) { 
            this.showToast('Week numbers out of range', 'error'); 
            return; 
        }
        this.saveHistory();
        weeks.forEach(w=>{ 
            if(type==='clear') delete this.blockedWeeks[w]; 
            else this.blockedWeeks[w] = {type, label: type}; 
        });
        this.renderEverything();
        this.showToast(`Applied to weeks ${weeks.join(', ')}`, 'success');
    }

