    <div class="modal" id="unitModal"><div class="modal-content"><div class="modal-header"><h3 id="modalTitle">Edit Unit</h3><button class="close-modal">&times;</button></div><div id="modalBody"></div></div></div>
    <div class="modal" id="termModal"><div class="modal-content"><div class="modal-header"><h3>Manage Term</h3><button class="close-modal">&times;</button></div><div id="termModalBody"></div></div></div>

