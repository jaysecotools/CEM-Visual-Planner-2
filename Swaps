        <main class="timeline-container"><div id="timelineContent"></div></main>
    </div>

    <!-- Student Term Overviews -->
    <div class="student-term-overviews" id="studentTermOverviews"></div>

    <!-- Footer -->
    <footer class="footer"><p>Course Mapping Tool v3.2 | Cert III Conservation & Ecosystem Management | <span id="totalWeeksDisplay">37</span> Teaching Weeks</p></footer>

