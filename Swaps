    init() {
        console.log('Initializing CoursePlanner v3.1...');
        this.setupEventListeners();
        this.loadInitialData();
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', () => {
                this.renderEverything();
                this.setupStudentViewIfNeeded();
                this.hideLoadingScreen();
                this.setupKeyboardShortcuts();
            });
        } else {
            this.renderEverything();
            this.setupStudentViewIfNeeded();
            this.hideLoadingScreen();
            this.setupKeyboardShortcuts();
        }
    }
        
    loadInitialData() {
        try {
            const urlParams = new URLSearchParams(window.location.search);
            this.isStudentView = urlParams.has('student');
            const sharedData = localStorage.getItem(CONFIG.SHARED_STORAGE_KEY);
            if (sharedData) {
                const data = JSON.parse(sharedData);
                this.loadFromData(data);
            } else {
                this.loadDefaultData();
            }
            this.saveHistory();
        } catch (error) {
            console.error('Error loading data:', error);
            this.loadDefaultData();
        }
    }

    loadFromData(data) {
        if (data.version === CONFIG.APP_VERSION || data.version === '3.0.0') {
            this.units = data.units || [...this.defaultUnits];
            this.courseData = data.courseData || this.courseData;
            this.blockedWeeks = data.blockedWeeks || {};
            this.customColors = data.customColors || {};
            if (this.courseData.projectMilestones) {
                this.courseData.projectMilestones = this.courseData.projectMilestones.map((milestone, index) => ({
                    ...milestone,
                    id: milestone.id || `milestone-${index + 1}`
                }));
            }
            console.log('✓ Loaded data, units:', this.units.length);
        } else {
            this.loadDefaultData();
        }
    }

    loadDefaultData() {
        this.units = JSON.parse(JSON.stringify(this.defaultUnits));
        this.courseData = {
            totalWeeks: CONFIG.DEFAULT_TOTAL_WEEKS,
            terms: [
                { number: 1, weeks: 10, startWeek: 1, name: "Safety, Foundations & Summer Harvest" },
                { number: 2, weeks: 10, startWeek: 11, name: "Practical Skills & Application" },
                { number: 3, weeks: 10, startWeek: 21, name: "Machinery & Advanced Integration" },
                { number: 4, weeks: 7, startWeek: 31, name: "Apex Units & Finalisation" }
            ],
            projectMilestones: [
                { id: 'milestone-1', week: 18, label: "Project Start" },
                { id: 'milestone-2', week: 25, label: "Phase 2" },
                { id: 'milestone-3', week: 30, label: "Integration" },
                { id: 'milestone-4', week: 34, label: "Final Phase" }
            ]
        };
        this.blockedWeeks = {};
        this.customColors = {};
    }

    saveData() {
        try {
            const dataToSave = {
                version: CONFIG.APP_VERSION,
                lastUpdate: new Date().toISOString(),
                units: JSON.parse(JSON.stringify(this.units)),
                courseData: JSON.parse(JSON.stringify(this.courseData)),
                blockedWeeks: JSON.parse(JSON.stringify(this.blockedWeeks)),
                customColors: JSON.parse(JSON.stringify(this.customColors))
            };
            localStorage.setItem(CONFIG.SHARED_STORAGE_KEY, JSON.stringify(dataToSave));
            console.log('✓ Data saved, units:', dataToSave.units.length);
            return true;
        } catch (error) {
            console.error('Save failed:', error);
            return false;
        }
    }

    saveHistory() {
        this.history = this.history.slice(0, this.historyIndex + 1);
        this.history.push({
            units: JSON.parse(JSON.stringify(this.units)),
            courseData: JSON.parse(JSON.stringify(this.courseData)),
            blockedWeeks: JSON.parse(JSON.stringify(this.blockedWeeks)),
            customColors: JSON.parse(JSON.stringify(this.customColors)),
            timestamp: Date.now()
        });
        if (this.history.length > 50) this.history.shift();
        this.historyIndex = this.history.length - 1;
        if (!this.isStudentView) this.saveData();
    }

    renderEverything() {
        this.renderUnitPalette();
        this.renderTimeline();
        this.renderSavedPlans();
        this.updateTotalWeeksDisplay();
        if (this.isStudentView) this.renderStudentTermOverviews();
    }

    renderUnitBlock(unit, week, isFirstWeek = false) {
        let bgColor = this.customColors[unit.id] || this.colorMap[unit.color] || this.colorMap.foundational;
        const darkColor = this.darkenColor(bgColor, 30);
        const assessmentBadge = unit.assessmentDue && isFirstWeek ? 
            `<div class="assessment-badge">📋 ASSESSMENT</div>` : '';
        return `
            <div class="unit-block" data-unit-id="${unit.id}" data-week="${week}"
                 style="background: ${bgColor}; border-left-color: ${darkColor}; cursor: ${this.isStudentView ? 'pointer' : 'move'};"
                 draggable="${!this.isStudentView}">
                ${assessmentBadge}
                <div class="unit-code">${unit.code}</div>
                ${isFirstWeek ? `<div class="unit-name">${unit.name}</div>` : ''}
                ${unit.weeks.length > 1 && isFirstWeek ? `<div class="unit-duration">${unit.weeks.length}w</div>` : ''}
                ${this.isStudentView && unit.teacher === 'other' ? `<div class="week-summary" style="color: #fd79a8;">Other Teacher</div>` : ''}
                ${this.isStudentView && unit.tags?.includes('SEASONAL') ? `<div class="week-summary" style="color: #55efc4;">Seasonal Timing</div>` : ''}
            </div>
        `;
    }

    // Enhanced timeline rendering with assessment highlights
    renderTimeline() {
        const container = document.getElementById('timelineContent');
        if (!container) return;

        const { totalWeeks, terms } = this.courseData;
        const weekWidth = this.isStudentView ? 120 : 150;
        document.documentElement.style.setProperty('--week-width', `${weekWidth}px`);
        let html = '';

        // Term headers
        html += `<div class="term-headers"><div class="term-spacer"></div>`;
        terms.forEach(term => {
            const termWidth = term.weeks * weekWidth;
            html += `<div class="term-header" data-term="${term.number}" style="width: ${termWidth}px; ${!this.isStudentView ? 'cursor: pointer;' : ''}">
                        Term ${term.number} (Weeks ${term.startWeek}-${term.startWeek + term.weeks - 1})
                        <div style="font-size: 12px; opacity: 0.8;">${term.name}</div>
                    </div>`;
        });
        html += `</div>`;

        // Week headers
        html += `<div class="week-headers"><div class="week-spacer"></div>`;
        for (let week = 1; week <= totalWeeks; week++) {
            html += `<div class="week-header" style="width: ${weekWidth}px;"><div class="week-number">Week ${week}</div></div>`;
        }
        html += `</div><div class="timeline-grid">`;

        // Swimlanes - removed Integrated Project row as requested
        const swimlanes = this.currentView === 'teacher' ? [
            { id: 'main', label: 'Main Teacher' },
            { id: 'other', label: 'Other Teacher' }
        ] : [
            { id: 'core', label: 'Core Units (Main Teacher)' },
            { id: 'specialist', label: 'Specialist Units (Other Teacher)' },
            { id: 'apex', label: 'Apex Units & Assessment' }
        ];

        swimlanes.forEach((lane, laneIndex) => {
            html += `<div class="swimlane" data-lane="${lane.id}"><div class="lane-label">${lane.label}</div><div class="lane-content" data-lane-id="${lane.id}">`;
            for (let week = 1; week <= totalWeeks; week++) {
                const isBlocked = this.blockedWeeks[week];
                const blockedClass = isBlocked ? 'blocked-week' : '';
                html += `<div class="week-slot ${blockedClass}" data-week="${week}" data-lane="${lane.id}" style="width: ${weekWidth}px;">`;
                if (isBlocked) {
                    html += `<div style="position: absolute; top: 5px; left: 5px; font-size: 10px; color: white; background: rgba(0,0,0,0.3); padding: 2px 5px; border-radius: 3px;">${this.blockingLabels[isBlocked.type] || 'BLOCKED'}</div>`;
                }
                const unitsInWeek = this.getUnitsForWeekAndLane(week, lane.id);
                if (unitsInWeek.length > 0) {
                    unitsInWeek.forEach(unit => {
                        const isFirstWeek = week === Math.min(...unit.weeks);
                        html += this.renderUnitBlock(unit, week, isFirstWeek);
                    });
                } else if (!isBlocked) {
                    html += `<div class="empty-slot">${this.isStudentView ? 'No units' : 'Drag unit here'}</div>`;
                }
                html += `</div>`;
            }
            html += `</div></div>`;
        });
        html += `</div>`;
        container.innerHTML = html;
        this.renderProjectMarkers();
        this.setupTimelineEvents();
        if (!this.isStudentView) {
            container.querySelectorAll('.term-header').forEach(header => {
                header.addEventListener('click', (e) => this.openTermModal(parseInt(e.currentTarget.dataset.term)));
            });
            const highlightMode = document.getElementById('highlightMode');
            if (highlightMode && highlightMode.value !== 'none') this.applyHighlighting(highlightMode.value);
        }
    }

    getUnitsForWeekAndLane(week, laneId) {
        if (laneId === 'main') return this.units.filter(u => u.weeks.includes(week) && u.teacher === 'main' && !u.tags?.includes('APEX'));
        if (laneId === 'other') return this.units.filter(u => u.weeks.includes(week) && u.teacher === 'other');
        if (laneId === 'core') return this.units.filter(u => u.weeks.includes(week) && u.teacher === 'main' && !u.tags?.includes('APEX') && u.code !== 'INTEGRATION' && u.code !== 'PROJECT');
        if (laneId === 'specialist') return this.units.filter(u => u.weeks.includes(week) && u.teacher === 'other');
        if (laneId === 'apex') return this.units.filter(u => u.weeks.includes(week) && (u.tags?.includes('APEX') || u.assessmentDue === true));
        return [];
    }

    renderProjectMarkers() {
        const apexLane = document.querySelector('.lane-content[data-lane-id="apex"]');
        if (!apexLane) return;
        const weekWidth = this.isStudentView ? 120 : 150;
        const laneHeight = apexLane.offsetHeight;
        document.querySelectorAll('.project-marker').forEach(m => m.remove());
        this.courseData.projectMilestones.forEach(milestone => {
            if (milestone.week < 1 || milestone.week > this.courseData.totalWeeks) return;
            const markerLeft = (milestone.week - 1) * weekWidth + weekWidth/2 - 8;
            const marker = document.createElement('div');
            marker.className = 'project-marker';
            marker.dataset.milestoneId = milestone.id;
            marker.dataset.week = milestone.week;
            marker.style.left = `${markerLeft}px`;
            marker.style.top = `${laneHeight / 2}px`;
            marker.style.position = 'absolute';
            const label = document.createElement('div');
            label.className = 'project-marker-label';
            label.textContent = milestone.label;
            marker.appendChild(label);
            if (!this.isStudentView) {
                const deleteBtn = document.createElement('div');
                deleteBtn.className = 'project-marker-delete';
                deleteBtn.innerHTML = '×';
                deleteBtn.addEventListener('click', (e) => { e.stopPropagation(); this.deleteProjectMilestone(milestone.id); });
                marker.appendChild(deleteBtn);
                marker.draggable = true;
                marker.addEventListener('dragstart', (e) => { e.dataTransfer.setData('text/plain', milestone.id); this.draggedMarker = milestone; marker.classList.add('dragging'); });
                marker.addEventListener('dragend', () => { marker.classList.remove('dragging'); this.draggedMarker = null; });
            }
            apexLane.appendChild(marker);
        });
        if (!this.isStudentView) {
            apexLane.addEventListener('dragover', e => e.preventDefault());
            apexLane.addEventListener('drop', e => {
                e.preventDefault();
                if (!this.draggedMarker) return;
                const rect = apexLane.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const week = Math.floor(x / weekWidth) + 1;
                if (week >= 1 && week <= this.courseData.totalWeeks) this.moveProjectMilestone(this.draggedMarker.id, week);
            });
        }
    }

    applyHighlighting(mode) {
        if (this.isStudentView) return;
        document.querySelectorAll('.unit-block').forEach(block => block.style.boxShadow = '');
        if (mode === 'none') return;
        let unitIds = [];
        if (mode === 'assessment') unitIds = this.units.filter(u => u.assessmentDue === true).map(u => u.id);
        else if (mode === 'specialist') unitIds = this.units.filter(u => u.tags?.includes('SPECIALIST') || u.teacher === 'other').map(u => u.id);
        else if (mode === 'safety') unitIds = this.units.filter(u => u.tags?.includes('SAFETY')).map(u => u.id);
        else if (mode === 'seasonal') unitIds = this.units.filter(u => u.tags?.includes('SEASONAL')).map(u => u.id);
        document.querySelectorAll('.unit-block').forEach(block => {
            if (unitIds.includes(block.dataset.unitId)) block.style.boxShadow = '0 0 0 3px gold, 0 4px 8px rgba(0,0,0,0.3)';
        });
    }

    // Enhanced unit modal with assessment toggle and custom color picker
    openUnitModal(unitId) {
        if (this.isStudentView) return;
        const unit = this.units.find(u => u.id === unitId);
        if (!unit) return;
        const modal = document.getElementById('unitModal');
        const modalBody = document.getElementById('modalBody');
        const modalTitle = document.getElementById('modalTitle');
        modalTitle.textContent = `Edit Unit: ${unit.code}`;
        const currentColor = this.customColors[unit.id] || this.colorMap[unit.color] || this.colorMap.foundational;
        modalBody.innerHTML = `
            <div style="display: flex; flex-direction: column; gap: 15px;">
                <div class="form-group"><label>Unit Code</label><input type="text" id="editUnitCode" value="${unit.code}"></div>
                <div class="form-group"><label>Unit Name</label><input type="text" id="editUnitName" value="${unit.name.replace(/"/g, '&quot;')}"></div>
                <div class="form-group"><label>Weeks (comma or range, e.g., 5-7)</label><input type="text" id="editUnitWeeks" value="${unit.weeks.join(',')}"></div>
                <div class="form-group"><label>Unit Type (color)</label><select id="editUnitColor">
                    ${Object.keys(this.colorMap).map(c => `<option value="${c}" ${unit.color === c ? 'selected' : ''}>${c}</option>`).join('')}
                </select></div>
                <div class="form-group"><label>Custom Color (override)</label><input type="color" id="editCustomColor" value="${currentColor}"></div>
                <div class="form-group"><label>Teacher</label><select id="editUnitTeacher"><option value="main" ${unit.teacher === 'main' ? 'selected' : ''}>Main Teacher</option><option value="other" ${unit.teacher === 'other' ? 'selected' : ''}>Other Teacher</option></select></div>
                <div class="form-group"><label>Assessment Task Due</label><select id="editAssessmentDue"><option value="true" ${unit.assessmentDue === true ? 'selected' : ''}>Yes - Show Assessment Badge</option><option value="false" ${unit.assessmentDue !== true ? 'selected' : ''}>No</option></select></div>
                <div class="form-group"><label>Tags (comma separated)</label><input type="text" id="editUnitTags" value="${unit.tags ? unit.tags.join(', ') : ''}"></div>
                <div class="form-group"><label>Notes</label><textarea id="editUnitNotes" rows="4">${unit.notes || ''}</textarea></div>
                <div style="display: flex; gap: 10px;"><button class="primary" onclick="window.app.saveUnitChanges('${unitId}')" style="flex:1;">Save Changes</button><button class="warning" onclick="window.app.deleteUnit('${unitId}')" style="flex:1;">Delete Unit</button><button onclick="document.getElementById('unitModal').style.display='none'" style="flex:1;">Cancel</button></div>
            </div>
        `;
        modal.style.display = 'flex';
    }

    saveUnitChanges(unitId) {
        const unitIndex = this.units.findIndex(u => u.id === unitId);
        if (unitIndex === -1) return;
        this.saveHistory();
        const unit = this.units[unitIndex];
        unit.code = document.getElementById('editUnitCode').value;
        unit.name = document.getElementById('editUnitName').value;
        unit.weeks = this.parseWeeksInput(document.getElementById('editUnitWeeks').value);
        unit.color = document.getElementById('editUnitColor').value;
        const customColor = document.getElementById('editCustomColor').value;
        if (customColor && customColor !== this.colorMap[unit.color]) this.customColors[unit.id] = customColor;
        else delete this.customColors[unit.id];
        unit.teacher = document.getElementById('editUnitTeacher').value;
        unit.assessmentDue = document.getElementById('editAssessmentDue').value === 'true';
        const tagsInput = document.getElementById('editUnitTags').value;
        unit.tags = tagsInput.split(',').map(t => t.trim()).filter(t => t.length);
        unit.notes = document.getElementById('editUnitNotes').value;
        document.getElementById('unitModal').style.display = 'none';
        this.renderEverything();
        this.showToast('Unit updated', 'success');
        this.showSyncNotification('Unit updated');
    }

    parseWeeksInput(input) {
        if (input.includes('-')) {
            const [start, end] = input.split('-').map(Number);
            return Array.from({length: end - start + 1}, (_, i) => start + i);
        } else if (input.includes(',')) return input.split(',').map(w => parseInt(w.trim())).filter(w => !isNaN(w));
        else return [parseInt(input) || 1];
    }

    deleteUnit(unitId) {
        if (confirm('Delete this unit?')) {
            this.saveHistory();
            this.units = this.units.filter(u => u.id !== unitId);
            document.getElementById('unitModal').style.display = 'none';
            this.renderEverything();
            this.showToast('Unit deleted', 'success');
        }
    }

    addProjectMilestone() {
        const week = prompt('Enter week for new project milestone (1-' + this.courseData.totalWeeks + '):');
        if (!week) return;
        const weekNum = parseInt(week);
        if (isNaN(weekNum) || weekNum < 1 || weekNum > this.courseData.totalWeeks) { this.showToast('Invalid week', 'error'); return; }
        const label = prompt('Enter milestone label:', 'New Milestone');
        if (!label) return;
        this.saveHistory();
        this.courseData.projectMilestones.push({ id: `milestone-${Date.now()}`, week: weekNum, label: label });
        this.renderEverything();
        this.showToast('Project milestone added', 'success');
    }

    moveProjectMilestone(milestoneId, newWeek) {
        const idx = this.courseData.projectMilestones.findIndex(m => m.id === milestoneId);
        if (idx === -1) return;
        this.saveHistory();
        this.courseData.projectMilestones[idx].week = newWeek;
        this.renderEverything();
        this.showToast('Milestone moved', 'success');
    }

    deleteProjectMilestone(milestoneId) {
        if (!confirm('Delete milestone?')) return;
        this.saveHistory();
        this.courseData.projectMilestones = this.courseData.projectMilestones.filter(m => m.id !== milestoneId);
        this.renderEverything();
        this.showToast('Milestone deleted', 'success');
    }

    clearAllProjectMilestones() {
        if (!confirm('Clear ALL milestones?')) return;
        this.saveHistory();
        this.courseData.projectMilestones = [];
        this.renderEverything();
        this.showToast('All milestones cleared', 'success');
    }

    setupStudentView() {
        document.body.classList.remove('editor-view');
        document.body.classList.add('student-view');
        const title = document.getElementById('courseTitle');
        const subtitle = document.getElementById('courseSubtitle');
        const indicator = document.getElementById('viewModeIndicator');
        const desc = document.getElementById('courseDescription');
        const viewIcon = document.getElementById('viewIcon');
        const viewLabel = document.getElementById('viewLabel');
        if (title) title.textContent = 'Course Schedule - Cert III Conservation & Ecosystem Management';
        if (subtitle) subtitle.textContent = `Student View - ${this.courseData.totalWeeks}-Week Plan`;
        if (indicator) indicator.textContent = 'Student View';
        if (desc) desc.textContent = 'Click units for details | Assessment tasks highlighted in orange';
        if (viewIcon) viewIcon.textContent = '✏️';
        if (viewLabel) viewLabel.textContent = 'Editor View';
        // Force a fresh render with cache-busting
        this.renderEverything();
    }

    setupStudentViewIfNeeded() {
        if (this.isStudentView) this.setupStudentView();
    }

    // Enhanced share link with cache-busting
    generateShareLink() {
        this.saveData();
        const baseUrl = window.location.origin + window.location.pathname;
        const timestamp = Date.now();
        const shareUrl = `${baseUrl}?student=true&v=${timestamp}&nocache=${timestamp}`;
        console.log('Share URL generated with cache-buster:', shareUrl);
        return shareUrl;
    }

    sharePlan() {
        if (this.isStudentView) return;
        this.showToast('Saving data for sharing...', 'info');
        if (!this.saveData()) { this.showToast('Save failed', 'error'); return; }
        const shareUrl = this.generateShareLink();
        const panel = document.getElementById('sharePanel');
        const input = document.getElementById('shareLink');
        if (input) input.value = shareUrl;
        panel.classList.add('show');
        const copyBtn = document.getElementById('copyShareLink');
        if (copyBtn) copyBtn.onclick = () => { input.select(); navigator.clipboard.writeText(input.value).then(() => this.showToast('Link copied!', 'success')); };
        this.showToast('Share link ready', 'success');
    }

    testStudentViewLink() {
        const shareUrl = this.generateShareLink();
        if (!shareUrl) return;
        const testWindow = window.open(shareUrl, '_blank', 'width=1200,height=800');
        if (testWindow) this.showToast('Test window opened', 'success');
        else this.showToast('Popup blocked', 'error');
    }

    moveUnit(unitId, week, lane) {
        const unitIndex = this.units.findIndex(u => u.id === unitId);
        if (unitIndex === -1) return;
        this.saveHistory();
        const unit = this.units[unitIndex];
        unit.weeks = [week];
        if (lane === 'specialist' || lane === 'other') { unit.teacher = 'other'; if (!unit.tags?.includes('SPECIALIST')) unit.tags = [...(unit.tags || []), 'SPECIALIST']; }
        else { unit.teacher = 'main'; unit.tags = (unit.tags || []).filter(t => t !== 'SPECIALIST'); }
        this.renderEverything();
        this.showSyncNotification('Unit moved');
    }

    addUnitFromTemplate(template, week, lane) {
        this.saveHistory();
        const newUnit = {
            id: Date.now().toString(),
            code: template.code === 'CUSTOM' ? `CUST${Date.now()}` : template.code,
            name: template.name,
            weeks: [week],
            color: template.color,
            tags: [...template.tags],
            teacher: lane === 'specialist' || lane === 'other' ? 'other' : 'main',
            notes: '',
            resources: [],
            assessmentDue: false
        };
        this.units.push(newUnit);
        this.renderEverything();
        this.showSyncNotification('Unit added');
        if (!this.isStudentView) setTimeout(() => this.openUnitModal(newUnit.id), 100);
    }

    // Week blocking and management methods (unchanged)
    applyWeekBlocking() {
        if (this.isStudentView) return;
        const blockingType = document.getElementById('weekBlocking').value;
        const weekRangeInput = document.getElementById('weekRange').value;
        if (!blockingType || !weekRangeInput) { this.showToast('Select type and range', 'error'); return; }
        let weeks = [];
        if (weekRangeInput.includes('-')) { const [s, e] = weekRangeInput.split('-').map(Number); weeks = Array.from({length: e-s+1}, (_,i)=>s+i); }
        else if (weekRangeInput.includes(',')) weeks = weekRangeInput.split(',').map(w=>parseInt(w.trim())).filter(w=>!isNaN(w));
        else weeks = [parseInt(weekRangeInput) || 1];
        this.saveHistory();
        weeks.forEach(week => { if (week>=1 && week<=this.courseData.totalWeeks) { if (blockingType === 'clear') delete this.blockedWeeks[week]; else this.blockedWeeks[week] = { type: blockingType, label: this.blockingLabels[blockingType] }; } });
        this.renderEverything();
        this.showToast(`Blocked weeks ${weeks.join(',')}`, 'success');
    }

    addWeek() { if (this.isStudentView) return; const pos = prompt(`Add week at position? (1-${this.courseData.totalWeeks+1})`); if(!pos) return; this.saveHistory(); let insertPos = parseInt(pos); if(isNaN(insertPos)) insertPos = this.courseData.totalWeeks+1; this.courseData.totalWeeks++; let termToUpdate = null; for(let t of this.courseData.terms) { if(insertPos >= t.startWeek) termToUpdate = t; } if(termToUpdate) termToUpdate.weeks++; for(let i=this.courseData.terms.findIndex(t=>t===termToUpdate)+1; i<this.courseData.terms.length; i++) this.courseData.terms[i].startWeek++; this.adjustUnitsForWeekInsertion(insertPos,1); this.renderEverything(); this.showToast('Week added','success'); }
    removeWeek() { if (this.isStudentView) return; const weekToRemove = parseInt(prompt(`Remove which week? (1-${this.courseData.totalWeeks})`)); if(isNaN(weekToRemove)) return; if(!confirm(`Remove Week ${weekToRemove}?`)) return; this.saveHistory(); this.courseData.totalWeeks--; let termIdx = -1; for(let i=0;i<this.courseData.terms.length;i++) { if(weekToRemove >= this.courseData.terms[i].startWeek && weekToRemove < this.courseData.terms[i].startWeek+this.courseData.terms[i].weeks) { termIdx=i; break; } } if(termIdx>=0) this.courseData.terms[termIdx].weeks--; for(let i=termIdx+1;i<this.courseData.terms.length;i++) this.courseData.terms[i].startWeek--; this.adjustUnitsForWeekRemoval(weekToRemove); this.renderEverything(); this.showToast('Week removed','success'); }
    adjustUnitsForWeekInsertion(insertPos, count) { this.units.forEach(u => { u.weeks = u.weeks.map(w => w >= insertPos ? w+count : w); }); const newBlocked = {}; Object.keys(this.blockedWeeks).forEach(w => { let wk = parseInt(w); newBlocked[wk >= insertPos ? wk+count : wk] = this.blockedWeeks[w]; }); this.blockedWeeks = newBlocked; this.courseData.projectMilestones.forEach(m => { if(m.week >= insertPos) m.week += count; }); }
    adjustUnitsForWeekRemoval(weekToRemove) { this.units = this.units.filter(u => !u.weeks.includes(weekToRemove)); this.units.forEach(u => { u.weeks = u.weeks.map(w => w > weekToRemove ? w-1 : w).filter(w => w !== weekToRemove); }); delete this.blockedWeeks[weekToRemove]; const newBlocked = {}; Object.keys(this.blockedWeeks).forEach(w => { let wk = parseInt(w); newBlocked[wk > weekToRemove ? wk-1 : wk] = this.blockedWeeks[w]; }); this.blockedWeeks = newBlocked; this.courseData.projectMilestones = this.courseData.projectMilestones.filter(m => m.week !== weekToRemove).map(m => m.week > weekToRemove ? {...m, week: m.week-1} : m); }
    addWeekToTerm() { if (this.isStudentView) return; const tn = parseInt(prompt('Add week to which term? (1-4)')); if(isNaN(tn)||tn<1||tn>4) return; this.saveHistory(); const term = this.courseData.terms[tn-1]; this.courseData.totalWeeks++; term.weeks++; for(let i=tn;i<this.courseData.terms.length;i++) this.courseData.terms[i].startWeek++; this.adjustUnitsForWeekInsertion(term.startWeek+term.weeks-1,1); this.renderEverything(); this.showToast(`Week added to Term ${tn}`,'success'); }
    removeWeekFromTerm() { if (this.isStudentView) return; const tn = parseInt(prompt('Remove week from which term? (1-4)')); if(isNaN(tn)||tn<1||tn>4) return; const term = this.courseData.terms[tn-1]; if(term.weeks<=1) { this.showToast('Term needs at least 1 week','error'); return; } const weekToRemove = term.startWeek+term.weeks-1; if(!confirm(`Remove week ${weekToRemove} from Term ${tn}?`)) return; this.saveHistory(); this.courseData.totalWeeks--; term.weeks--; for(let i=tn;i<this.courseData.terms.length;i++) this.courseData.terms[i].startWeek--; this.adjustUnitsForWeekRemoval(weekToRemove); this.renderEverything(); this.showToast(`Week removed from Term ${tn}`,'success'); }
    renderUnitPalette() { if(this.isStudentView) return; const c = document.getElementById('unitPalette'); if(!c) return; c.innerHTML = this.unitTemplates.map(t => `<div class="unit-item" draggable="true" data-template='${JSON.stringify(t)}' style="border-left:4px solid ${this.colorMap[t.color]}"><div class="unit-code">${t.code}</div><div class="unit-name">${t.name}</div><div style="display:flex;gap:5px;margin-top:5px;">${t.tags.map(tg=>`<span style="font-size:10px;padding:2px 6px;border-radius:10px;background:#e9ecef;">${tg}</span>`).join('')}</div></div>`).join(''); c.querySelectorAll('.unit-item').forEach(i => { i.addEventListener('dragstart',e=>{ e.dataTransfer.setData('text/plain',JSON.stringify(JSON.parse(i.dataset.template))); i.classList.add('dragging');}); i.addEventListener('dragend',e=>i.classList.remove('dragging')); }); }
    renderSavedPlans() { if(this.isStudentView) return; const c = document.getElementById('savedPlans'); if(!c) return; try{ const plans = JSON.parse(localStorage.getItem('cet_plans')||'[]'); if(plans.length===0) c.innerHTML='<p style="color:#666;">No saved plans.</p>'; else c.innerHTML = plans.map(p => `<div style="padding:10px;margin-bottom:10px;background:#f8f9fa;border-radius:6px;border-left:4px solid #0984e3;"><div style="font-weight:600;">${p.name}</div><div style="font-size:12px;color:#666;">${new Date(p.date).toLocaleDateString()} • ${p.units?.length||0} units</div><div style="display:flex;gap:5px;"><button onclick="window.app.loadPlan('${p.id}')" style="flex:1;padding:5px;background:#0984e3;color:white;border:none;border-radius:4px;">Load</button><button onclick="window.app.deleteSavedPlan('${p.id}')" style="flex:1;padding:5px;background:#ff6b6b;color:white;border:none;border-radius:4px;">Delete</button></div></div>`).join(''); }catch(e){ c.innerHTML='<p>Error loading plans</p>'; } }
    savePlan() { if(this.isStudentView) return; const name = prompt('Plan name:', `Plan ${new Date().toLocaleDateString()}`); if(!name) return; const plan = { id:Date.now().toString(), name, date:new Date().toISOString(), units:this.units, courseData:this.courseData, blockedWeeks:this.blockedWeeks, customColors:this.customColors, version:CONFIG.APP_VERSION }; let plans = JSON.parse(localStorage.getItem('cet_plans')||'[]'); plans.push(plan); localStorage.setItem('cet_plans',JSON.stringify(plans)); this.renderSavedPlans(); this.showToast(`Plan "${name}" saved`,'success'); }
    loadPlan(id) { const plans = JSON.parse(localStorage.getItem('cet_plans')||'[]'); const plan = plans.find(p=>p.id===id); if(plan) { this.saveHistory(); this.units = plan.units||[]; this.courseData = plan.courseData||this.courseData; this.blockedWeeks = plan.blockedWeeks||{}; this.customColors = plan.customColors||{}; this.renderEverything(); this.showToast(`Loaded "${plan.name}"`,'success'); } }
    deleteSavedPlan(id) { if(confirm('Delete plan?')) { let plans = JSON.parse(localStorage.getItem('cet_plans')||'[]'); plans = plans.filter(p=>p.id!==id); localStorage.setItem('cet_plans',JSON.stringify(plans)); this.renderSavedPlans(); this.showToast('Plan deleted','success'); } }
    resetToDefault() { if(confirm('Reset to default?')) { this.saveHistory(); this.units = JSON.parse(JSON.stringify(this.defaultUnits)); this.courseData = { totalWeeks:CONFIG.DEFAULT_TOTAL_WEEKS, terms:[{number:1,weeks:10,startWeek:1,name:"Safety, Foundations & Summer Harvest"},{number:2,weeks:10,startWeek:11,name:"Practical Skills & Application"},{number:3,weeks:10,startWeek:21,name:"Machinery & Advanced Integration"},{number:4,weeks:7,startWeek:31,name:"Apex Units & Finalisation"}], projectMilestones:[{id:'milestone-1',week:18,label:"Project Start"},{id:'milestone-2',week:25,label:"Phase 2"},{id:'milestone-3',week:30,label:"Integration"},{id:'milestone-4',week:34,label:"Final Phase"}] }; this.blockedWeeks={}; this.customColors={}; this.renderEverything(); this.showToast('Reset to default','success'); } }
    clearTimetable() { if(confirm('Clear ALL units?')) { this.saveHistory(); this.units=[]; this.renderEverything(); this.showToast('Timetable cleared','success'); } }
    exportAsList() { this.generatePlainTextList(); }
    generatePlainTextList() { let text = `COURSE SCHEDULE - CERTIFICATE III CONSERVATION & ECOSYSTEM MANAGEMENT\nGenerated: ${new Date().toLocaleString()}\nTotal Weeks: ${this.courseData.totalWeeks} | Units: ${this.units.length}\n\nASSESSMENT TASKS (highlighted with 📋):\n`; this.units.filter(u=>u.assessmentDue).forEach(u=>{ const weeks = u.weeks; text += `• ${u.code}: ${u.name} - Due Week ${Math.min(...weeks)}-${Math.max(...weeks)}\n`; }); text += `\nTERM BREAKDOWN:\n`; this.courseData.terms.forEach(term=>{ text += `\nTERM ${term.number}: ${term.name} (Weeks ${term.startWeek}-${term.startWeek+term.weeks-1})\n`; const termUnits = this.units.filter(u=>u.weeks.some(w=>w>=term.startWeek && w<term.startWeek+term.weeks)); const unique = []; const seen = new Set(); termUnits.forEach(u=>{ if(!seen.has(u.id)){ seen.add(u.id); unique.push(u); } }); unique.sort((a,b)=>Math.min(...a.weeks)-Math.min(...b.weeks)).forEach(u=>{ text += `  • ${u.code}: ${u.name} (Weeks ${Math.min(...u.weeks)}-${Math.max(...u.weeks)})${u.assessmentDue?' 📋 ASSESSMENT':''}\n`; }); }); const blob = new Blob([text],{type:'text/plain'}); const a = document.createElement('a'); a.href=URL.createObjectURL(blob); a.download=`course-schedule-${new Date().toISOString().split('T')[0]}.txt`; a.click(); URL.revokeObjectURL(a.href); this.showToast('Exported as text','success'); }
    printFullSchedule() { document.body.classList.add('pdf-export-mode'); setTimeout(()=>{ window.print(); setTimeout(()=>document.body.classList.remove('pdf-export-mode'),1000); },100); }
    saveAsPDF() { this.showToast('Use "Print Full Schedule" and choose "Save as PDF"','info'); this.printFullSchedule(); }
    printStudentView() { const wasStudent = this.isStudentView; if(!wasStudent) this.setupStudentView(); setTimeout(()=>{ window.print(); if(!wasStudent) { this.isStudentView = false; document.body.classList.remove('student-view'); document.body.classList.add('editor-view'); this.renderEverything(); } },500); }
    openTermModal(termNumber) { const term = this.courseData.terms.find(t=>t.number===termNumber); if(!term) return; const modal = document.getElementById('termModal'); const body = document.getElementById('termModalBody'); body.innerHTML = `<div><h4>Term ${term.number}: ${term.name}</h4><p>Weeks: ${term.startWeek}-${term.startWeek+term.weeks-1} (${term.weeks} weeks)</p><div class="form-group"><label>Term Name</label><input type="text" id="termName" value="${term.name}"></div><div class="form-group"><label>Weeks in Term</label><input type="number" id="termWeeks" value="${term.weeks}" min="1" max="15"></div><div style="display:flex;gap:10px;margin-top:20px;"><button class="primary" onclick="window.app.saveTermChanges(${term.number})">Save</button><button onclick="document.getElementById('termModal').style.display='none'">Cancel</button></div></div>`; modal.style.display='flex'; }
    saveTermChanges(termNumber) { const term = this.courseData.terms.find(t=>t.number===termNumber); if(term) { const newName = document.getElementById('termName').value; const newWeeks = parseInt(document.getElementById('termWeeks').value); if(newName) term.name = newName; if(newWeeks && newWeeks !== term.weeks) { this.saveHistory(); const diff = newWeeks - term.weeks; term.weeks = newWeeks; this.courseData.totalWeeks += diff; let startAdjust = false; for(let i=0;i<this.courseData.terms.length;i++) { if(this.courseData.terms[i].number === termNumber) startAdjust=true; else if(startAdjust) this.courseData.terms[i].startWeek += diff; } this.renderEverything(); } else { this.renderEverything(); } } document.getElementById('termModal').style.display='none'; this.showToast('Term updated','success'); }
    renderStudentTermOverviews() { const container = document.getElementById('studentTermOverviews'); if(!container) return; let html = ''; this.courseData.terms.forEach(term=>{ const termUnits = this.units.filter(u=>u.weeks.some(w=>w>=term.startWeek && w<term.startWeek+term.weeks)); const unique = []; const seen = new Set(); termUnits.forEach(u=>{ if(!seen.has(u.id)){ seen.add(u.id); unique.push(u); } }); unique.sort((a,b)=>Math.min(...a.weeks)-Math.min(...b.weeks)); html += `<div class="term-overview"><h3>Term ${term.number}: ${term.name}</h3><div class="term-units">${unique.map(u=>`<div class="term-unit-card"><div style="font-weight:600;color:#0984e3;">${u.code}</div><div style="font-size:13px;">${u.name}</div>${u.assessmentDue?'<div style="color:#ff9f4a;font-size:11px;">📋 Assessment Due</div>':''}</div>`).join('')}</div></div>`; }); container.innerHTML = html; }
    showStudentUnitDetails(unitId) { const unit = this.units.find(u=>u.id===unitId); if(!unit) return; const modal = document.getElementById('unitModal'); const modalBody = document.getElementById('modalBody'); const modalTitle = document.getElementById('modalTitle'); modalTitle.textContent = `${unit.code} - ${unit.name}`; modalBody.innerHTML = `<div><div style="background:#f8f9fa;padding:10px;border-radius:6px;margin-bottom:15px;"><div>Weeks: ${Math.min(...unit.weeks)}-${Math.max(...unit.weeks)} (${unit.weeks.length} week${unit.weeks.length>1?'s':''})</div><div>Teacher: ${unit.teacher==='other'?'Other Teacher':'Main Teacher'}</div>${unit.assessmentDue?'<div style="color:#ff9f4a;font-weight:bold;">📋 Assessment Task Due</div>':''}</div>${unit.notes?`<div style="background:#f8f9fa;padding:10px;border-radius:6px;">${unit.notes}</div>`:''}<button onclick="document.getElementById('unitModal').style.display='none'" style="margin-top:15px;width:100%;padding:10px;background:#0984e3;color:white;border:none;border-radius:6px;">Close</button></div>`; modal.style.display='flex'; }
    setupTimelineEvents() { const container = document.getElementById('timelineContent'); if(!container) return; container.querySelectorAll('.unit-block').forEach(block=>{ block.addEventListener('click',e=>{ e.stopPropagation(); const unitId = block.dataset.unitId; if(this.isStudentView) this.showStudentUnitDetails(unitId); else this.openUnitModal(unitId); }); if(!this.isStudentView){ block.addEventListener('dragstart',e=>{ const unitId = block.dataset.unitId; const unit = this.units.find(u=>u.id===unitId); if(unit){ this.draggedUnit = unit; e.dataTransfer.setData('text/plain',JSON.stringify({type:'move',unitId})); block.classList.add('dragging'); } }); block.addEventListener('dragend',e=>{ block.classList.remove('dragging'); this.draggedUnit = null; }); } }); if(!this.isStudentView){ container.querySelectorAll('.week-slot').forEach(slot=>{ slot.addEventListener('dragover',e=>e.preventDefault()); slot.addEventListener('drop',e=>{ e.preventDefault(); const week = parseInt(slot.dataset.week); const lane = slot.dataset.lane; try{ const data = JSON.parse(e.dataTransfer.getData('text/plain')); if(data.type==='move') this.moveUnit(data.unitId, week, lane); else this.addUnitFromTemplate(data, week, lane); this.showToast('Unit placed','success'); }catch(err){ console.warn('Drop error',err); } }); }); } }
    setupEventListeners() { const vm = document.getElementById('viewMode'); if(vm && !this.isStudentView) vm.addEventListener('change',e=>{ this.currentView = e.target.value; this.renderTimeline(); }); const hm = document.getElementById('highlightMode'); if(hm) hm.addEventListener('change',e=>this.applyHighlighting(e.target.value)); const savePlan = document.getElementById('savePlan'); if(savePlan) savePlan.addEventListener('click',()=>this.savePlan()); const sharePlan = document.getElementById('sharePlan'); if(sharePlan) sharePlan.addEventListener('click',()=>this.sharePlan()); const resetPlan = document.getElementById('resetPlan'); if(resetPlan) resetPlan.addEventListener('click',()=>this.resetToDefault()); const clearTimetable = document.getElementById('clearTimetable'); if(clearTimetable) clearTimetable.addEventListener('click',()=>this.clearTimetable()); const printPlan = document.getElementById('printPlan'); if(printPlan) printPlan.addEventListener('click',()=>this.printFullSchedule()); const exportPlan = document.getElementById('exportPlan'); if(exportPlan) exportPlan.addEventListener('click',()=>this.exportPlan()); const exportList = document.getElementById('exportList'); if(exportList) exportList.addEventListener('click',()=>this.exportAsList()); const applyBlocking = document.getElementById('applyBlocking'); if(applyBlocking) applyBlocking.addEventListener('click',()=>this.applyWeekBlocking()); const addWeek = document.getElementById('addWeekBtn'); if(addWeek) addWeek.addEventListener('click',()=>this.addWeek()); const removeWeek = document.getElementById('removeWeekBtn'); if(removeWeek) removeWeek.addEventListener('click',()=>this.removeWeek()); const addWeekToTerm = document.getElementById('addWeekToTermBtn'); if(addWeekToTerm) addWeekToTerm.addEventListener('click',()=>this.addWeekToTerm()); const removeWeekFromTerm = document.getElementById('removeWeekFromTermBtn'); if(removeWeekFromTerm) removeWeekFromTerm.addEventListener('click',()=>this.removeWeekFromTerm()); const addMarker = document.getElementById('addProjectMarker'); if(addMarker) addMarker.addEventListener('click',()=>this.addProjectMilestone()); const clearMarkers = document.getElementById('clearProjectMarkers'); if(clearMarkers) clearMarkers.addEventListener('click',()=>this.clearAllProjectMilestones()); const addCustom = document.getElementById('addCustomUnit'); if(addCustom) addCustom.addEventListener('click',()=>this.addUnitFromTemplate({code:'CUSTOM',name:'Custom Unit/Block',color:'foundational',tags:['CUSTOM']},1,'core')); const importPlanBtn = document.getElementById('importPlanBtn'); if(importPlanBtn) importPlanBtn.addEventListener('click',()=>this.importPlan()); const toggleView = document.getElementById('toggleView'); if(toggleView) toggleView.addEventListener('click',()=>this.toggleViewMode()); document.querySelectorAll('.close-modal').forEach(btn=>btn.addEventListener('click',function(){ this.closest('.modal').style.display='none'; })); const preview = document.getElementById('previewStudentView'); if(preview) preview.addEventListener('click',()=>{ const url = this.generateShareLink(); if(url) window.open(url,'_blank'); }); const openTab = document.getElementById('openStudentViewTab'); if(openTab) openTab.addEventListener('click',()=>{ const url = this.generateShareLink(); if(url) window.open(url,'_blank'); }); const testLink = document.getElementById('testStudentView'); if(testLink) testLink.addEventListener('click',()=>this.testStudentViewLink()); const printFull = document.getElementById('printFullSchedule'); if(printFull) printFull.addEventListener('click',()=>this.printFullSchedule()); const savePDF = document.getElementById('saveAsPDF'); if(savePDF) savePDF.addEventListener('click',()=>this.saveAsPDF()); const printStudent = document.getElementById('printStudentView'); if(printStudent) printStudent.addEventListener('click',()=>this.printStudentView()); const exportCSV = document.getElementById('exportCSV'); if(exportCSV) exportCSV.addEventListener('click',()=>this.exportAsList()); const exportText = document.getElementById('exportTextList'); if(exportText) exportText.addEventListener('click',()=>this.generatePlainTextList()); }
    exportPlan() { const data = { version:CONFIG.APP_VERSION, timestamp:new Date().toISOString(), units:this.units, courseData:this.courseData, blockedWeeks:this.blockedWeeks, customColors:this.customColors }; const blob = new Blob([JSON.stringify(data,null,2)],{type:'application/json'}); const a = document.createElement('a'); a.href=URL.createObjectURL(blob); a.download=`course-plan-${new Date().toISOString().split('T')[0]}.json`; a.click(); URL.revokeObjectURL(a.href); this.showToast('Plan exported','success'); }
    importPlan() { const fileInput = document.getElementById('importPlan'); if(!fileInput.files.length) return; const file = fileInput.files[0]; const reader = new FileReader(); reader.onload = e => { try{ const data = JSON.parse(e.target.result); if(data.units && data.courseData){ this.saveHistory(); this.units = data.units; this.courseData = data.courseData; this.blockedWeeks = data.blockedWeeks||{}; this.customColors = data.customColors||{}; this.renderEverything(); this.showToast('Plan imported','success'); } else this.showToast('Invalid plan','error'); }catch(err){ this.showToast('Import failed','error'); } }; reader.readAsText(file); fileInput.value=''; }
    toggleViewMode() { if(this.isStudentView) window.location.href = window.location.pathname; else this.sharePlan(); }
    showToast(msg, type='info') { const c = document.getElementById('toastsContainer') || (()=>{ const d=document.createElement('div'); d.id='toastsContainer'; document.body.appendChild(d); return d; })(); const t = document.createElement('div'); t.className=`toast toast-${type}`; t.textContent=msg; c.appendChild(t); setTimeout(()=>{ t.style.opacity='0'; setTimeout(()=>t.remove(),300); },3000); }
    showSyncNotification(msg) { const s = document.getElementById('syncStatus'); const m = document.getElementById('syncMessage'); if(s && m){ m.textContent=msg+' (synced)'; s.classList.add('show'); setTimeout(()=>s.classList.remove('show'),3000); } }
    hideLoadingScreen() { const l = document.getElementById('loading'); if(l){ l.style.opacity='0'; setTimeout(()=>l.style.display='none',300); } }
    darkenColor(color, percent) { if(!color) return '#666'; let r,g,b; if(color.startsWith('#')){ r=parseInt(color.slice(1,3),16); g=parseInt(color.slice(3,5),16); b=parseInt(color.slice(5,7),16); } else return '#666'; const amt = Math.round(2.55*percent); return `#${((Math.max(0,r-amt))<16?'0':'')+Math.max(0,r-amt).toString(16)}${((Math.max(0,g-amt))<16?'0':'')+Math.max(0,g-amt).toString(16)}${((Math.max(0,b-amt))<16?'0':'')+Math.max(0,b-amt).toString(16)}`; }
    setupKeyboardShortcuts() { document.addEventListener('keydown',e=>{ if(e.target.matches('input,textarea,select')) return; if(e.ctrlKey||e.metaKey){ if(e.key==='z'){ e.preventDefault(); if(e.shiftKey) this.redo(); else this.undo(); } else if(e.key==='y'){ e.preventDefault(); this.redo(); } else if(e.key==='s'){ e.preventDefault(); this.savePlan(); } else if(e.key==='p'){ e.preventDefault(); this.printFullSchedule(); } } if(e.key==='Escape'){ document.querySelectorAll('.modal').forEach(m=>m.style.display='none'); const p = document.getElementById('sharePanel'); if(p) p.classList.remove('show'); } }); }
    undo() { if(this.historyIndex>0){ this.historyIndex--; const s=this.history[this.historyIndex]; this.units=JSON.parse(JSON.stringify(s.units)); this.courseData=JSON.parse(JSON.stringify(s.courseData)); this.blockedWeeks=JSON.parse(JSON.stringify(s.blockedWeeks)); this.customColors=JSON.parse(JSON.stringify(s.customColors||{})); this.renderEverything(); this.showToast('Undo','success'); return true; } return false; }
    redo() { if(this.historyIndex<this.history.length-1){ this.historyIndex++; const s=this.history[this.historyIndex]; this.units=JSON.parse(JSON.stringify(s.units)); this.courseData=JSON.parse(JSON.stringify(s.courseData)); this.blockedWeeks=JSON.parse(JSON.stringify(s.blockedWeeks)); this.customColors=JSON.parse(JSON.stringify(s.customColors||{})); this.renderEverything(); this.showToast('Redo','success'); return true; } return false; }
    updateTotalWeeksDisplay() { const d = document.getElementById('totalWeeksDisplay'); if(d) d.textContent = this.courseData.totalWeeks; }
    getTermForWeek(week) { return this.courseData.terms.find(t => week >= t.startWeek && week < t.startWeek + t.weeks); }
}

let app;
document.addEventListener('DOMContentLoaded',()=>{ app = new CoursePlanner(); window.app = app; });
</script>
