renderUnitPalette() {
    if (this.isStudentView) return;
    
    const container = document.getElementById('unitPalette');
    if (!container) {
        console.error('Unit palette container not found');
        return;
    }

    console.log('Rendering unit palette with', this.unitTemplates.length, 'templates');
    
    // Check if unitTemplates exists
    if (!this.unitTemplates || this.unitTemplates.length === 0) {
        console.error('No unit templates found');
        container.innerHTML = '<p>Error: No units available</p>';
        return;
    }
    
    container.innerHTML = this.unitTemplates.map(template => {
        const color = this.colorMap[template.color] || '#4ecdc4';
        return `
            <div class="unit-item" draggable="true" data-template='${JSON.stringify(template)}'
                 style="border-left: 4px solid ${color}; margin-bottom: 8px;">
                <div class="unit-code">${template.code}</div>
                <div class="unit-name">${template.name}</div>
                <div style="display: flex; gap: 5px; margin-top: 5px; flex-wrap: wrap;">
                    ${template.tags.map(tag => `
                        <span style="font-size: 10px; padding: 2px 6px; border-radius: 10px; background: #e9ecef; color: #495057;">
                            ${tag}
                        </span>
                    `).join('')}
                </div>
            </div>
        `;
    }).join('');

    // Add drag event listeners
    const unitItems = container.querySelectorAll('.unit-item');
    if (unitItems.length === 0) {
        console.warn('No unit items created');
        return;
    }
    
    unitItems.forEach(item => {
        item.addEventListener('dragstart', (e) => {
            try {
                const template = JSON.parse(e.currentTarget.dataset.template);
                this.draggedFromPalette = true;
                this.draggedUnit = template;
                e.dataTransfer.setData('text/plain', JSON.stringify(template));
                e.currentTarget.classList.add('dragging');
            } catch (error) {
                console.error('Drag start failed:', error);
            }
        });

        item.addEventListener('dragend', (e) => {
            e.currentTarget.classList.remove('dragging');
            this.draggedFromPalette = false;
            this.draggedUnit = null;
        });
    });
    
    console.log('Unit palette rendered with', unitItems.length, 'items');
}
```

