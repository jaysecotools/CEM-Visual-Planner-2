        };
        
        // Try to render immediately
        if (!checkDOMAndRender()) {
            // If not ready, wait for DOMContentLoaded
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', () => {
                    checkDOMAndRender();
                });
            } else {
