    exportAsList() {
        let text = `COURSE SCHEDULE - CERT III CONSERVATION & ECOSYSTEM MANAGEMENT\n`;
        text += `Generated: ${new Date().toLocaleString()}\n`;
        text += `Total Units: ${this.units.length}\n`;
        text += `Total Weeks: ${this.courseData.totalWeeks}\n`;
        text += `${'='.repeat(60)}\n\n`;
        text += `ASSESSMENT TASKS:\n`;
        const assessments = this.units.filter(u => u.assessmentDue);
        if (assessments.length) {
            assessments.forEach(u => { text += `  • ${u.code}: ${u.name} - Week ${Math.min(...u.weeks)}\n`; });
        } else { text += `  None\n`; }
        text += `\nWEEK-BY-WEEK BREAKDOWN:\n`;
        for (let w = 1; w <= this.courseData.totalWeeks; w++) {
            const unitsHere = this.units.filter(u => u.weeks.includes(w));
            if (unitsHere.length) {
                text += `Week ${w}: ${unitsHere.map(u => `${u.code}${u.assessmentDue ? '📋' : ''}`).join(', ')}\n`;
            }
        }
        const a = document.createElement('a');
        a.href = URL.createObjectURL(new Blob([text], {type:'text/plain'}));
        a.download = `schedule-${new Date().toISOString().split('T')[0]}.txt`;
        a.click();
        this.showToast('Exported as text', 'success');
    }

