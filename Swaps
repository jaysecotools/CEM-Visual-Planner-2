        if(toggle) toggle.addEventListener('click',()=>{ if(this.isStudentView) window.location.href=window.location.pathname; else this.sharePlan(); });
        
        const share = document.getElementById('sharePlan');
        if(share) share.addEventListener('click',()=>this.sharePlan());
        
        const closeShare = document.getElementById('closeSharePanel');
        if(closeShare) closeShare.addEventListener('click',()=>document.getElementById('sharePanel').classList.remove('show'));
        
        const copyLink = document.getElementById('copyShareLink');
        if(copyLink) copyLink.addEventListener('click',()=>{ const inp=document.getElementById('shareLink'); inp.select(); navigator.clipboard.writeText(inp.value); this.showToast('Link copied!','success'); });
        
        const savePlan = document.getElementById('savePlan');
        if(savePlan) savePlan.addEventListener('click',()=>this.savePlan());
        
        const resetPlan = document.getElementById('resetPlan');
        if(resetPlan) resetPlan.addEventListener('click',()=>this.resetToDefault());
        
        const clearTimetable = document.getElementById('clearTimetable');
        if(clearTimetable) clearTimetable.addEventListener('click',()=>this.clearTimetable());
        
        const printPlan = document.getElementById('printPlan');
        if(printPlan) printPlan.addEventListener('click',()=>this.printFullSchedule());
        
        const exportPlan = document.getElementById('exportPlan');
        if(exportPlan) exportPlan.addEventListener('click',()=>this.exportPlan());
        
        const exportList = document.getElementById('exportList');
        if(exportList) exportList.addEventListener('click',()=>this.exportAsList());
        
        const applyBlock = document.getElementById('applyBlocking');
        if(applyBlock) applyBlock.addEventListener('click',()=>this.applyWeekBlocking());
        
        const addAssessment = document.getElementById('addAssessmentUnit');
        if(addAssessment) addAssessment.addEventListener('click',()=>this.addAssessmentUnit());
        
        const viewMode = document.getElementById('viewMode');
        if(viewMode) viewMode.addEventListener('change',e=>{ this.currentView = e.target.value; this.renderTimeline(); });
        
        const highlightMode = document.getElementById('highlightMode');
        if(highlightMode) highlightMode.addEventListener('change',e=>this.applyHighlighting(e.target.value));
        
        // FIXED: Import button event listener
        const importBtn = document.getElementById('importPlanBtn');
        if(importBtn) importBtn.addEventListener('click',()=>this.importPlanFromFile());
        
        const addCustom = document.getElementById('addCustomUnit');
        if(addCustom) addCustom.addEventListener('click',()=>this.addUnitFromTemplate({code:'CUSTOM',name:'Custom Unit',color:'foundational',tags:['CUSTOM']}, 1, 'core'));
        
        document.querySelectorAll('.close-modal').forEach(btn=>btn.addEventListener('click',function(){ this.closest('.modal').style.display='none'; }));
        document.querySelectorAll('.modal').forEach(m=>{ m.addEventListener('click',e=>{ if(e.target===m) m.style.display='none'; }); });
    }
