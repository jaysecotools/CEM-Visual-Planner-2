    savePlan() {
        const name = prompt('Plan name:', `Plan ${new Date().toLocaleDateString()}`);
        if (!name) return;
        const plans = JSON.parse(localStorage.getItem('cet_plans')||'[]');
        plans.push({ 
            id: Date.now().toString(), 
            name, 
            date: new Date().toISOString(), 
            units: JSON.parse(JSON.stringify(this.units)), 
            courseData: JSON.parse(JSON.stringify(this.courseData)), 
            blockedWeeks: JSON.parse(JSON.stringify(this.blockedWeeks)), 
            customColors: JSON.parse(JSON.stringify(this.customColors)) 
        });
        localStorage.setItem('cet_plans', JSON.stringify(plans));
        this.renderSavedPlans();
        this.showToast(`Plan "${name}" saved`, 'success');
    }

    loadPlan(id) {
        const plans = JSON.parse(localStorage.getItem('cet_plans')||'[]');
        const p = plans.find(p=>p.id===id);
        if(p) { 
            this.saveHistory(); 
            this.units = JSON.parse(JSON.stringify(p.units)); 
            this.courseData = JSON.parse(JSON.stringify(p.courseData)); 
            this.blockedWeeks = JSON.parse(JSON.stringify(p.blockedWeeks||{})); 
            this.customColors = JSON.parse(JSON.stringify(p.customColors||{}));
            this.renderEverything(); 
            this.saveData();
            this.showToast(`Loaded "${p.name}"`, 'success'); 
        }
    }

    deletePlan(id) {
        if(!confirm('Delete this saved plan?')) return;
        let plans = JSON.parse(localStorage.getItem('cet_plans')||'[]');
        plans = plans.filter(p=>p.id!==id);
        localStorage.setItem('cet_plans', JSON.stringify(plans));
        this.renderSavedPlans();
        this.showToast('Plan deleted','success');
    }

    // FIXED: JSON Import functionality - fully working
    importPlanFromFile() {
        const fileInput = document.getElementById('importPlan');
        if (!fileInput || !fileInput.files.length) {
            this.showToast('Please select a JSON file to import', 'error');
            return;
        }
        const file = fileInput.files[0];
        if (!file.name.endsWith('.json')) {
            this.showToast('Please select a .json file', 'error');
            fileInput.value = '';
            return;
        }
        const reader = new FileReader();
        reader.onload = (e) => {
            try {
                const importedData = JSON.parse(e.target.result);
                // Validate imported data
                if (!importedData.units && !importedData.courseData) {
                    this.showToast('Invalid plan file: missing required data', 'error');
                    return;
                }
                this.saveHistory();
                // Load units
                if (importedData.units && Array.isArray(importedData.units)) {
                    this.units = JSON.parse(JSON.stringify(importedData.units));
                    // Ensure all units have required properties
                    this.units.forEach(unit => {
                        if (unit.assessmentDue === undefined) unit.assessmentDue = false;
                        if (!unit.weeks) unit.weeks = [1];
                        if (!unit.tags) unit.tags = [];
                        if (!unit.teacher) unit.teacher = 'main';
                        if (!unit.color && unit.assessmentDue) unit.color = 'assessment';
                        if (!unit.color) unit.color = 'foundational';
                        if (!unit.id) unit.id = Date.now().toString() + Math.random();
                    });
                }
                // Load course data
                if (importedData.courseData) {
                    this.courseData = JSON.parse(JSON.stringify(importedData.courseData));
                    if (!this.courseData.projectMilestones) this.courseData.projectMilestones = [];
                    if (!this.courseData.terms) this.courseData.terms = this.defaultCourseData().terms;
                    if (!this.courseData.totalWeeks) this.courseData.totalWeeks = CONFIG.DEFAULT_TOTAL_WEEKS;
                }
                // Load blocked weeks
                if (importedData.blockedWeeks) this.blockedWeeks = JSON.parse(JSON.stringify(importedData.blockedWeeks));
                // Load custom colors
                if (importedData.customColors) this.customColors = JSON.parse(JSON.stringify(importedData.customColors));
                
                this.renderEverything();
                this.saveData();
                this.showToast(`Successfully imported ${this.units.length} units`, 'success');
                fileInput.value = '';
            } catch (error) {
                console.error('Import error:', error);
                this.showToast('Failed to import: Invalid JSON format', 'error');
                fileInput.value = '';
            }
        };
        reader.onerror = () => {
            this.showToast('Failed to read file', 'error');
            fileInput.value = '';
        };
        reader.readAsText(file);
    }

