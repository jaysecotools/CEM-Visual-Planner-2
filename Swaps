        <button id="resetPlan">🔄 Reset</button>
        <button id="printPlan">🖨️ Print</button>
        <button id="exportPlan">📤 Export JSON</button>
        <button id="exportList" class="success">📋 Export List</button>
        <button id="clearTimetable" class="warning">🗑️ Clear All</button>
        <div class="control-group"><label>Add Assessment Task</label><button id="addAssessmentUnit" class="success" style="background:#ff9f4a;">📋 + Assessment Task</button></div>
    </div>

