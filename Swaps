    renderStudentTermOverviews() {
        const c = document.getElementById('studentTermOverviews');
        if(!c) return;
        let html = '';
        this.courseData.terms.forEach(term=>{
            const termUnits = this.units.filter(u=>u.weeks.some(w=>w>=term.startWeek && w<term.startWeek+term.weeks));
            const unique = new Map();
            termUnits.forEach(u=>{ if(!unique.has(u.id)) unique.set(u.id,u); });
            const sorted = Array.from(unique.values()).sort((a,b)=>Math.min(...a.weeks)-Math.min(...b.weeks));
            html += `<div class="term-overview"><h3>Term ${term.number}: ${escapeHtml(term.name)}</h3><div class="term-units">${sorted.map(u=>`<div class="term-unit-card"><div style="font-weight:600;color:#0984e3;">${escapeHtml(u.code)}</div><div style="font-size:13px;">${escapeHtml(u.name)}</div>${u.assessmentDue?'<div style="color:#e67e22;font-size:11px;">📋 Assessment Due</div>':''}</div>`).join('')}</div></div>`;
        });
        c.innerHTML = html;
    }

